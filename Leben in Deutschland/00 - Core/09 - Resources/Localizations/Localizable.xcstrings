    },
    "settings_about_description": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hero – Einbürgerungstest hilft dir bei der Vorbereitung auf den Einbürgerungstest mit 310 offiziellen Fragen, Spaced-Repetition-Lernen und vollständiger Testsimulation. Wähle dein Bundesland, übe in deinem eigenen Tempo und fühle dich am Prüfungstag sicher."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hero – Einbürgerungstest helps you prepare for the citizenship test with 310 official questions, spaced repetition learning, and a full test simulation. Choose your federal state, practice at your own pace, and feel confident on exam day."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Hero – Einbürgerungstest помогает подготовиться к тесту на гражданство: 310 официальных вопросов, интервальное повторение и полная симуляция экзамена. Выбери федеральную землю, занимайся в своём темпе и чувствуй себя уверенно в день экзамена."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hero – Vatandaşlık Testi, 310 resmi soru, Aralıklı Tekrar öğrenimi ve tam test simülasyonu ile vatandaşlık sınavına hazırlanmana yardımcı olur. Eyaletini seç, kendi hızında çalış ve sınav günü kendini güvende hisset."
          }
        }
      }
    },
