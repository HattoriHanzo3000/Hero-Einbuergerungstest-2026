    "learn_by_topics_disclaimer_message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Fragen sind nach Themen gruppiert, damit du ein Thema nach dem anderen lernen kannst. Wähle ein Thema, beantworte die Fragen und prüfe deine Antworten. Dieser Modus beeinflusst nicht deinen Bereitschaftsstand."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Questions are grouped by theme so you can study one topic at a time. Choose a topic, answer the questions, and check your answers. This mode does not affect your readiness score."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вопросы сгруппированы по темам, чтобы ты мог изучать их по одной. Выбери тему, ответь на вопросы и проверь себя. Этот режим не влияет на показатель готовности."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sorular, konuları sırayla öğrenebilmen için konulara göre gruplandırılmıştır. Bir konu seç, soruları cevapla ve cevaplarını kontrol et. Bu mod sınava hazır olma durumunu etkilemez."
          }
        }
      }
    },
    "hero_pro_view_plans": {
