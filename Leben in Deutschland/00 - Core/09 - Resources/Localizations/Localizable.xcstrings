    "about_disclaimer": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hero – Einbürgerungstest ist eine unabhängige Lern-App und steht in keiner Verbindung zum Bundesamt für Migration und Flüchtlinge (BAMF). Die App ist weder autorisiert, gesponsert noch empfohlen. Der offizielle Test und der Fragenkatalog werden vom BAMF bereitgestellt und veröffentlicht. Alle Marken, Produktnamen und Rechte gehören ihren jeweiligen Inhabern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hero – Einbürgerungstest is an independent learning app and is not affiliated with, authorized by, sponsored by, or endorsed by the Bundesamt für Migration und Flüchtlinge (BAMF). The official test and question catalog are administered and published by BAMF. All trademarks, product names, and rights belong to their respective owners."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Hero – Einbürgerungstest — независимое учебное приложение и не связано с Федеральным ведомством по делам миграции и беженцев Германии (BAMF), не авторизовано, не спонсируется и не одобряется им. Официальный тест и каталог вопросов администрируются и публикуются BAMF. Все товарные знаки, названия продуктов и права принадлежат их соответствующим владельцам."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hero – Einbürgerungstest bağımsız bir öğrenme uygulamasıdır ve Bundesamt für Migration und Flüchtlinge (BAMF) ile bağlantılı değildir; BAMF tarafından yetkilendirilmez, sponsorlanmaz veya onaylanmaz. Resmi sınav ve soru kataloğu BAMF tarafından yönetilir ve yayımlanır. Tüm ticari markalar, ürün adları ve haklar ilgili sahiplerine aittir."
          }
        }
      }
    },
