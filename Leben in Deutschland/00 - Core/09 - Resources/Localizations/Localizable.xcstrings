    "feedback_email_hint": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn du deine E-Mail angibst, können wir auf dein Feedback antworten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you provide your email, we can respond to your feedback."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если ты укажешь свой email, мы сможем ответить на твою обратную связь."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "E-postanı girersen, geri bildirimine yanıt verebiliriz."
          }
        }
      }
    },
    "settings_language_change_message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Oberfläche wird aktualisiert. Fortfahren?"
