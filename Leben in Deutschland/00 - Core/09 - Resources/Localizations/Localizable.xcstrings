    "rating_prompt_message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn Hero dir dabei hilft, die Fragen zu meistern, würden wir gerne davon hören! Eine kurze Bewertung hilft auch anderen Lernenden, uns zu entdecken."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If Hero's been helping you ace those questions, we'd love to hear about it! A quick rating helps other learners discover us too."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если Hero помогает тебе справляться с вопросами, мы будем рады узнать об этом! Быстрая оценка помогает другим ученикам тоже нас найти."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Eğer Hero soruları kavramana yardımcı oluyorsa, bunu duymak isteriz! Kısa bir değerlendirme, diğer öğrenenlerin de bizi keşfetmesine yardımcı olur."
          }
        }
      }
    },
