    "date_too_far_message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeitreisen sind cool, aber lass den Test innerhalb des nächsten Jahres – ok?"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Time travel’s cool, but let’s keep the test within the next year—deal?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Путешествия во времени — это круто, но давай оставим тест в пределах следующего года, договорились?"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaman yolculuğu havalı ama hadi sınavı önümüzdeki bir yıl içinde tutalım, tamam mı?"
          }
        }
      }
    },
