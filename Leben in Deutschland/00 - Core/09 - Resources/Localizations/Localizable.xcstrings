    },
    "onboarding_date_prompt": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wann ist dein Test? Wähle das Datum und wir zählen gemeinsam die Tage."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When's your test? Set the date and we'll count down together."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда твой экзамен? Выбери дату и мы будем вести обратный отсчёт вместе."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sınavın ne zaman? Tarihi seç, günleri birlikte sayalım."
          }
        }
      }
    },
