    "favorites_disclaimer_message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das sind die Fragen, die du während des Übens gespeichert hast. Tippe in jedem Modus auf das Herz-Symbol, um Fragen hinzuzufügen oder zu entfernen. Dieser Bereich ist zum Wiederholen – jede Frage wird mit der richtigen Antwort angezeigt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "These are the questions you've saved during practice. Tap the heart icon in any mode to add or remove questions. This section is for review—each question is shown with its correct answer."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Здесь вопросы, которые ты сохранил во время практики. Нажимай на сердечко в любом режиме, чтобы добавить или убрать вопросы. Этот раздел для повторения — каждый вопрос показан с правильным ответом."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bunlar pratik yaparken kaydettiğin sorular. Soruları eklemek veya çıkarmak için herhangi bir modda kalp simgesine dokun. Bu alan tekrar içindir – her soru doğru cevabıyla birlikte gösterilir."
          }
        }
      }
    },
