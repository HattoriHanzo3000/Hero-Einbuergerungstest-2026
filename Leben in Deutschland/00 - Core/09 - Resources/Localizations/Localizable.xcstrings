    "feedback_submitted_message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vielen Dank für dein Feedback! Wir werden es prüfen und Verbesserungen vornehmen."
