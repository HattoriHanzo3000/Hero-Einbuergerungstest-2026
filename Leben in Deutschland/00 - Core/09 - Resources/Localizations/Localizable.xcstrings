    "all_questions_disclaimer_message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alle 310 offiziellen Prüfungsfragen sind hier in chronologischer Reihenfolge aufgelistet – wie in den offiziellen Prüfungsunterlagen. Dieser Bereich ist nur zum Lesen: Jede Frage wird mit der richtigen Antwort angezeigt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All 310 official exam questions are listed here in chronological order, as in the official exam materials. This section is for reading only—each question is shown with its correct answer."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Все 310 официальных экзаменационных вопросов представлены здесь в хронологическом порядке, как в официальных экзаменационных материалах. Этот раздел только для чтения — каждый вопрос показан с правильным ответом."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "310 resmi sınav sorusunun tamamı, resmi sınav belgelerinde olduğu gibi burada kronolojik sırayla listelenmiştir. Bu bölüm sadece okumak içindir: Her soru doğru cevabıyla birlikte gösterilir."
          }
        }
      }
    },
