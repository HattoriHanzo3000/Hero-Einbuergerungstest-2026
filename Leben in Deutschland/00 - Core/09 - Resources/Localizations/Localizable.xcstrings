    "eagle_greeting": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hallo! Ich bin Hero, der Adler, und ich helfe dir bei der Vorbereitung auf den Test. Lass uns anfangen!\nWähle zuerst die Sprache der App und tippe dann auf „Weiter“."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hello! I'm Hero the eagle, and I'll help you get ready for the test. Let's begin!\nFirst, choose the app language, then tap Next."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Привет! Я орёл Херо, и я помогу тебе подготовиться к тесту. Давай начнём!\nСначала выбери язык приложения, затем нажми «Далее»."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Merhaba! Ben kartal Hero, sınava hazırlanmana yardım edeceğim. Hadi başlayalım!\nÖnce uygulama dilini seç, ardından İleri'ye dokun."
          }
        }
      }
    },
