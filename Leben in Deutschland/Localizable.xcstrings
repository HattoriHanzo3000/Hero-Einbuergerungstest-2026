    "Progress" : {

    },
    "progress_readiness_explanation" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das ist deine Bereitschaftsbewertung. Je höher der Prozentsatz, desto näher bist du an der Prüfungsbereitschaft; %@ heißt volle Bereitschaft. Das erreichst du, wenn du jede der %d Fragen viermal richtig beantwortest. Die vier Farben zeigen, wie viele Fragen du pro Stufe hast: einmal (Bekannt), zweimal (Gefestigt), dreimal (Beherrscht) oder viermal bzw. öfter (Experte)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This is your readiness score. The higher the percentage, the closer you are to being ready for the exam; %@ means full readiness. You can reach that by answering each of the %d questions correctly four times. The four colors show how many questions you've got at each level: once (Familiar), twice (Reinforced), three times (Mastered), or four and more (Expert)."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это твоя оценка готовности. Чем выше процент, тем ближе ты к готовности к экзамену; %@ означают полную готовность. Такого результата можно достичь, если ответить правильно на каждый из %d вопросов четыре раза. Четыре цвета показывают количество по уровням: один раз правильно (Знакомо), два (Закреплено), три (Усвоено), четыре и больше (Эксперт)."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu senin sınava hazır olma puanın. Yüzde ne kadar yüksekse, sınava o kadar hazırsın demektir; %@ tam hazır olduğunu gösterir. Buna, %d sorunun her birini dört kez doğru cevapladığında ulaşırsın. Dört renk, her seviyede kaç sorunun olduğunu gösterir: bir kez (Tanıdık), iki kez (Pekiştirilmiş), üç kez (Kavranmış) veya dört kez ve üzeri (Uzman)."
          }
        }
      }
    },
    "progress_readiness_explanation_full" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das ist deine Bereitschaftsbewertung. Je höher der Prozentsatz, desto näher bist du an der Prüfungsbereitschaft; %@ heißt volle Bereitschaft. Das erreichst du, wenn du jede der %d Fragen viermal richtig beantwortest. Jede Farbe steht für eine Stufe: Bekannt - einmal richtig beantwortet, Gefestigt - zweimal richtig beantwortet, Beherrscht - dreimal richtig beantwortet, Experte - viermal oder öfter richtig beantwortet. Nur Fragen aus %@ und %@ zählen für diesen Stand."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This is your readiness score. The higher the percentage, the closer you are to being ready for the exam; %@ means full readiness. You can reach that by answering each of the %d questions correctly four times. Each color shows a different stage: Familiar - answered correctly once, Reinforced - answered correctly twice, Mastered - answered correctly three times, Expert - answered correctly four times or more. Only questions from %@ and %@ count toward this score."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это твоя оценка готовности. Чем выше процент, тем ближе ты к готовности к экзамену; %@ означают полную готовность. Такого результата можно достичь, если ответить правильно на каждый из %d вопросов четыре раза. Каждый цвет — свой уровень: Знакомо - ответил правильно один раз, Закреплено - ответил правильно два раза, Усвоено - ответил правильно три раза, Эксперт - ответил правильно четыре раза и больше. Только вопросы из %@ и %@ учитываются в этом показателе."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu senin sınava hazır olma puanın. Yüzde ne kadar yüksekse, sınava o kadar hazırsın demektir; %@ tam hazır olduğunu gösterir. Buna, %d sorunun her birini dört kez doğru cevapladığında ulaşırsın. Her renk bir seviyeyi temsil eder: Tanıdık - bir kez doğru cevaplandı, Pekiştirilmiş - iki kez doğru cevaplandı, Kavranmış - üç kez doğru cevaplandı, Uzman - dört veya daha fazla kez doğru cevaplandı. Sadece %@ ve %@ kategorilerindeki sorular bu duruma etki eder."
          }
        }
      }
    },
