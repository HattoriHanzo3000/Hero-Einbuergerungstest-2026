    "test_simulation_disclaimer_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieser Modus simuliert die offizielle Einbürgerungsprüfung: 33 Fragen (30 bundesweit, 3 aus deinem Bundesland), 60 Minuten, ein Versuch. Keine Tipps oder Übersetzungen während des Tests. Zum Bestehen brauchst du mindestens 17 richtige Antworten. Dieser Modus beeinflusst deinen Bereitschaftsstand."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This mode simulates the official citizenship exam: 33 questions (30 federal, 3 from your state), 60 minutes, single attempt. No hints or translations during the test. You need at least 17 correct answers to pass. This mode affects your readiness score."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Этот режим симулирует официальный экзамен на гражданство: 33 вопроса (30 федеральных, 3 по твоей земле), 60 минут, одна попытка. Без подсказок и переводов во время теста. Чтобы сдать, нужно минимум 17 правильных ответов. Этот режим влияет на показатель готовности."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu mod resmi vatandaşlık sınavını simüle eder: 33 soru (30 genel, 3 kendi eyaletinden), 60 dakika, tek hak. Test sırasında ipucu veya çeviri yoktur. Geçmek için en az 17 doğru cevap vermelisin. Bu mod sınava hazır olma durumunu etkiler."
          }
        }
      }
    },
