    "sr_disclaimer_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Intervall-Wiederholung ist ein wissenschaftlich fundiertes System: Fragen werden in optimalen Abständen wiederholt – so lernst du schneller und behältst mehr. Dieser Modus beeinflusst deinen Fortschritt und Bereitschaftsstand."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spaced repetition is a science-based system that repeats questions at optimal intervals—helping you learn faster and retain more. This mode affects your progress and readiness score."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Интервальное повторение — это научно обоснованная система: вопросы возвращаются в оптимальные интервалы — так ты учишься быстрее и запоминаешь надолго. Этот режим влияет на твой прогресс и показатель готовности."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aralıklı tekrar, bilimsel olarak kanıtlanmış bir sistemdir: Sorular en uygun aralıklarla tekrarlanır, böylece daha hızlı öğrenir ve daha fazlasını aklında tutarsın. Bu mod ilerlemeni ve sınava hazır olma durumunu etkiler."
          }
        }
      }
    },
    "sr_disclaimer_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Intervall-Wiederholungssystem"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spaced Repetition System"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Система интервального повторения"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aralıklı Tekrar Sistemi"
          }
        }
      }
    },
