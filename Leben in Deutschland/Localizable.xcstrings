          }
        }
      }
    },
    "learn_by_topics_header_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ich habe alle Fragen für dich nach Themen gruppiert — wähle deinen Weg und leg los."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I grouped all questions by themes for you — choose a path and soar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Я сгруппировал все вопросы по темам — выбирай маршрут и взлетай."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Senin için tüm soruları konulara göre gruplandırdım — kendi yolunu seç ve başla."
          }
        }
      }
    },
    "learn_option_test_description" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entspricht der offiziellen Prüfung: 33 Fragen (30 bundesweit, 3 aus deinem Bundesland), 60 Minuten, ein Versuch. Keine Tipps oder Korrekturen. Ideal, um deine Bereitschaft zu prüfen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Matches the official exam: 33 questions (30 federal, 3 from your state), 60 minutes, single attempt. No hints or corrections. A great way to check your readiness."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Соответствует официальному экзамену: 33 вопроса (30 общих, 3 по твоей земле), 60 минут, одна попытка. Без подсказок и исправлений. Отличный способ проверить готовность."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resmi sınavla birebir aynı: 33 soru (30 genel, 3 kendi eyaletinden), 60 dakika, tek hak. İpucu veya düzeltme yok. Hazır olup olmadığını görmek için ideal."
          }
        }
      }
    },
