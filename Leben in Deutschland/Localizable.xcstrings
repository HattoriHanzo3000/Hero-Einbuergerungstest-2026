    "eagle_desc_chick" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du bist zu %@ bereit. Los geht's! Du hebst langsam ab."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're %@ ready. Let's go! You're learning to flap your wings."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Готовность %@. Вперёд! Первые взмахи крыльев уже за тобой."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ hazırsın. Hadi bakalım! Yavaş yavaş havalanıyorsun."
          }
        }
      }
    },
    "eagle_desc_egg" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du bist zu %@ bereit für den Test. Du bist gerade geschlüpft! Auf zu neuen Erkenntnissen!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're %@ ready for the test. You've just hatched! Time to learn and grow!"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Готовность к тесту — %@. Первые шаги! Вперёд к знаниям!"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sınava %@ hazırsın. Daha yeni yumurtadan çıktın! Yeni bilgilere doğru!"
          }
        }
      }
    },
    "eagle_desc_growing" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du bist zu %@ bereit. Du fliegst richtig gut! Fast geschafft!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're %@ ready. You're flying high! Almost there."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Готовность %@. Отличный полёт! До вершины — рукой подать."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ hazırsın. Gerçekten iyi uçuyorsun! Neredeyse başardın!"
          }
        }
      }
    },
    "eagle_desc_master" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du bist zu %@ bereit. Du bist ein echter Wissens-Adler!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're %@ ready. You're a true knowledge eagle!"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Готовность %@. Ты — орёл знаний!"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ hazırsın. Sen gerçek bir bilgi kartalısın!"
          }
        }
      }
    },
    "eagle_desc_wise" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du bist zu %@ bereit. Nur noch ein kleiner Flug – du schaffst das!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're %@ ready. Just one more flight — you've got this!"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Готовность %@. Осталось совсем чуть-чуть — не сбавляй высоты!"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ hazırsın. Sadece küçük bir uçuş kaldı – bunu başarabilirsin!"
          }
        }
      }
    },
    "eagle_desc_young" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du bist zu %@ bereit. Deine Flügel werden stärker – weiter so!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're %@ ready. Your wings are getting stronger — keep going!"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Готовность %@. Крылья крепнут! Продолжай в том же духе."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ hazırsın. Kanatların güçleniyor – böyle devam et!"
          }
        }
      }
    },
    "eagle_greeting" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hallo! Ich bin Hero, der Adler, und ich helfe dir bei der Vorbereitung auf den Test. Lass uns anfangen!\nWähle zuerst die Sprache der App und tippe dann auf „Weiter“."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hello! I'm Hero the eagle, and I'll help you get ready for the test. Let's begin!\nFirst, choose the app language, then tap Next."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Привет! Я орёл Херо, и я помогу тебе подготовиться к тесту. Давай начнём!\nСначала выбери язык приложения, затем нажми «Далее»."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Merhaba! Ben kartal Hero, sınava hazırlanmana yardım edeceğim. Hadi başlayalım!\nÖnce uygulama dilini seç, ardından İleri'ye dokun."
          }
        }
      }
    },
