    "advertisement_hero_lead_subtitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entdecke auch unsere anderen Hero-Apps - sie unterstützen dich dabei, deine Ziele zu erreichen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Explore our other Hero apps—they're here to help you reach your goals."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Открой и другие приложения Hero — они помогут тебе достичь целей."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diğer Hero uygulamalarımızı da keşfet - hedeflerine ulaşmana yardımcı olurlar."
          }
        }
      }
    },
    "advertisement_hero_lead_title" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hero ist mehr als nur eine App. Es ist dein Begleiter für ein erfolgreiches Leben in Deutschland"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hero is more than just an app. It is your companion for a successful life in Germany"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hero — это больше, чем просто приложение. Это твой спутник для успешной жизни в Германии"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hero sadece bir uygulama değil. Almanya'da başarılı bir yaşam için yol arkadaşın."
          }
        }
      }
    },
    "all_questions_disclaimer_message" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle 310 offiziellen Prüfungsfragen sind hier in chronologischer Reihenfolge aufgelistet – wie in den offiziellen Prüfungsunterlagen. Dieser Bereich ist nur zum Lesen: Jede Frage wird mit der richtigen Antwort angezeigt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All 310 official exam questions are listed here in chronological order, as in the official exam materials. This section is for reading only—each question is shown with its correct answer."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Все 310 официальных экзаменационных вопросов представлены здесь в хронологическом порядке, как в официальных экзаменационных материалах. Этот раздел только для чтения — каждый вопрос показан с правильным ответом."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "310 resmi sınav sorusunun tamamı, resmi sınav belgelerinde olduğu gibi burada kronolojik sırayla listelenmiştir. Bu bölüm sadece okumak içindir: Her soru doğru cevabıyla birlikte gösterilir."
          }
        }
      }
    },
